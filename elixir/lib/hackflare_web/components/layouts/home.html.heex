<!DOCTYPE html>
<html lang="en">
  <body class="bg-base-100 text-base-content">
    <div class="min-h-screen flex flex-col">
      <header class="sticky top-0 z-50 border-b border-base-300/30 bg-base-100/80 backdrop-blur-xl">
        <div class="mx-auto max-w-7xl px-6 lg:px-8">
          <div class="flex h-16 items-center justify-between">
            <a href="/" class="flex items-center gap-3 flex-shrink-0">
              <img src={~p"/images/logo.svg"} width="36" alt="HackFlare" />
              <span class="hidden text-xl font-bold tracking-tight sm:inline">HackFlare</span>
            </a>

            <nav class="hidden lg:flex items-center gap-8">
              <a
                href="#features"
                class="text-sm font-medium text-base-content/70 hover:text-base-content transition"
              >
                Features
              </a>
              <a
                href="#how-it-works"
                class="text-sm font-medium text-base-content/70 hover:text-base-content transition"
              >
                How it works
              </a>
              <a
                href="/docs"
                class="text-sm font-medium text-base-content/70 hover:text-base-content transition"
              >
                Docs
              </a>
            </nav>

            <div class="flex items-center gap-3">
              <a
                href="https://github.com/Hack-Flare/hackflare"
                class="hidden sm:inline-flex text-sm font-medium text-base-content/70 hover:text-base-content transition"
              >
                GitHub
              </a>
              <a
                href="/auth/request"
                class="inline-flex px-4 py-2 text-sm font-semibold text-base-content/70 hover:text-base-content transition"
              >
                Sign in
              </a>
              <a
                href="/dash"
                class="inline-flex px-5 py-2 rounded-lg bg-red-600 text-white font-semibold text-sm hover:bg-red-700 transition-colors"
              >
                Get Started
              </a>
            </div>
          </div>
        </div>
      </header>

      <main class="flex-1">
        <section class="relative px-6 py-20 lg:py-32 overflow-hidden">
          <div class="absolute inset-0 -z-10">
            <div class="absolute top-20 left-1/3 h-96 w-96 rounded-full bg-red-600/5 blur-3xl">
            </div>
            <div class="absolute bottom-20 right-1/4 h-96 w-96 rounded-full bg-blue-600/5 blur-3xl">
            </div>
          </div>

          <div class="mx-auto max-w-7xl">
            <div class="grid gap-12 lg:gap-16 lg:items-center">
              <div class="space-y-6">
                <h1 class="max-w-2xl text-5xl font-bold leading-[1.05] tracking-tight sm:text-6xl lg:text-7xl">
                  The DNS platform for builders.
                </h1>

                <p class="max-w-xl text-xl leading-relaxed text-base-content/70">
                  HackFlare helps you point your domain, manage DNS records, and ship faster. Built by Hack Clubbers.
                </p>

                <div class="flex flex-col gap-4 sm:flex-row">
                  <a
                    href="/dash"
                    class="inline-flex items-center justify-center rounded-lg bg-red-600 px-6 py-3 font-semibold text-white transition-colors hover:bg-red-700"
                  >
                    Launch Dashboard
                  </a>
                  <a
                    href="/docs"
                    class="inline-flex items-center justify-center rounded-lg border border-base-300 bg-base-100 px-6 py-3 font-semibold transition-colors hover:bg-base-200"
                  >
                    Read Docs
                  </a>
                </div>
              </div>

              <div></div>
            </div>
          </div>
        </section>

        <section id="features" class="px-6 py-20 lg:py-32">
          <div class="mx-auto max-w-7xl">
            <div class="mx-auto mb-16 max-w-2xl text-center">
              <h2 class="text-4xl font-bold leading-tight lg:text-5xl">
                Everything you need to manage DNS.
              </h2>
              <p class="mt-6 text-xl text-base-content/70">
                Clean tools for delegation, records, and the day-to-day DNS work behind a live project.
              </p>
            </div>

            <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
              <div class="group rounded-xl border border-base-300/50 bg-base-100 p-8 transition-all hover:border-red-600/30 hover:shadow-lg">
                <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-lg bg-red-600/10 transition group-hover:bg-red-600/20">
                  <.icon name="hero-bolt" class="h-6 w-6 text-red-600" />
                </div>
                <h3 class="text-lg font-bold">Edge Performance</h3>
                <p class="mt-3 text-base-content/70">Built to feel super fast and direct.</p>
              </div>

              <div class="group rounded-xl border border-base-300/50 bg-base-100 p-8 transition-all hover:border-red-600/30 hover:shadow-lg">
                <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-lg bg-red-600/10 transition group-hover:bg-red-600/20">
                  <.icon name="hero-shield-check" class="h-6 w-6 text-red-600" />
                </div>
                <h3 class="text-lg font-bold">Good Security</h3>
                <p class="mt-3 text-base-content/70">
                  Great defaults, clear states and better UX than cloudflare.
                </p>
              </div>

              <div class="group rounded-xl border border-base-300/50 bg-base-100 p-8 transition-all hover:border-red-600/30 hover:shadow-lg">
                <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-lg bg-red-600/10 transition group-hover:bg-red-600/20">
                  <.icon name="hero-code-bracket-square" class="h-6 w-6 text-red-600" />
                </div>
                <h3 class="text-lg font-bold">Automation Friendly</h3>
                <p class="mt-3 text-base-content/70">
                  Wonderful Rest and gRPC APIs that allow you to automate everything.
                </p>
              </div>

              <div class="group rounded-xl border border-base-300/50 bg-base-100 p-8 transition-all hover:border-red-600/30 hover:shadow-lg">
                <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-lg bg-red-600/10 transition group-hover:bg-red-600/20">
                  <.icon name="hero-user-group" class="h-6 w-6 text-red-600" />
                </div>
                <h3 class="text-lg font-bold">Made for Hack Club</h3>
                <p class="mt-3 text-base-content/70">
                  Made by the Hack Club community for the Hack Club community.
                </p>
              </div>

              <div class="group rounded-xl border border-base-300/50 bg-base-100 p-8 transition-all hover:border-red-600/30 hover:shadow-lg">
                <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-lg bg-red-600/10 transition group-hover:bg-red-600/20">
                  <.icon name="hero-book-open" class="h-6 w-6 text-red-600" />
                </div>
                <h3 class="text-lg font-bold">Docs That Help</h3>
                <p class="mt-3 text-base-content/70">
                  Useful docs, obvious guides, and useful AI integration.
                </p>
              </div>

              <div class="group rounded-xl border border-base-300/50 bg-base-100 p-8 transition-all hover:border-red-600/30 hover:shadow-lg">
                <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-lg bg-red-600/10 transition group-hover:bg-red-600/20">
                  <.icon name="hero-globe-alt" class="h-6 w-6 text-red-600" />
                </div>
                <h3 class="text-lg font-bold">Global Reach</h3>
                <p class="mt-3 text-base-content/70">A great network for more scaling.</p>
              </div>
            </div>
          </div>
        </section>

        <section id="how-it-works" class="bg-base-200/30 px-6 py-20 lg:py-32">
          <div class="mx-auto max-w-7xl">
            <div class="mx-auto mb-16 max-w-2xl text-center">
              <h2 class="text-4xl font-bold leading-tight lg:text-5xl">
                Get started in minutes.
              </h2>
              <p class="mt-6 text-xl text-base-content/70">
                Point your nameservers, add records, and you're done. No complex setup required.
              </p>
            </div>

            <div class="space-y-8">
              <div class="grid gap-8 items-center lg:grid-cols-12">
                <div class="lg:col-span-5">
                  <div class="mb-4 inline-block rounded-full bg-red-600/10 px-4 py-2 text-sm font-semibold text-red-600">
                    Step 1
                  </div>
                  <h3 class="mb-4 text-3xl font-bold">Sign in with Hack Club</h3>
                  <p class="text-lg text-base-content/70">
                    Use your Hack Club account to access your dashboard.
                  </p>
                </div>
                <div class="lg:col-span-7">
                  <div class="rounded-xl border border-base-300/50 bg-base-100 p-6">
                    <div class="flex aspect-video items-center justify-center rounded-lg bg-base-200">
                      <.icon name="hero-lock-closed" class="h-16 w-16 text-base-content/20" />
                    </div>
                  </div>
                </div>
              </div>

              <div class="grid gap-8 items-center lg:grid-cols-12">
                <div class="lg:col-span-7">
                  <div class="rounded-xl border border-base-300/50 bg-base-100 p-6">
                    <div class="flex aspect-video items-center justify-center rounded-lg bg-base-200">
                      <.icon name="hero-globe-alt" class="h-16 w-16 text-base-content/20" />
                    </div>
                  </div>
                </div>
                <div class="lg:col-span-5">
                  <div class="mb-4 inline-block rounded-full bg-red-600/10 px-4 py-2 text-sm font-semibold text-red-600">
                    Step 2
                  </div>
                  <h3 class="mb-4 text-3xl font-bold">Point your domain</h3>
                  <p class="text-lg text-base-content/70">
                    Update your domain's nameservers to HackFlare. We'll guide you through the process.
                  </p>
                </div>
              </div>

              <div class="grid gap-8 items-center lg:grid-cols-12">
                <div class="lg:col-span-5">
                  <div class="mb-4 inline-block rounded-full bg-red-600/10 px-4 py-2 text-sm font-semibold text-red-600">
                    Step 3
                  </div>
                  <h3 class="mb-4 text-3xl font-bold">Manage your records</h3>
                  <p class="text-lg text-base-content/70">
                    Add A, AAAA, CNAME, MX, and all other DNS records with a great interface.
                  </p>
                </div>
                <div class="lg:col-span-7">
                  <div class="rounded-xl border border-base-300/50 bg-base-100 p-6">
                    <div class="flex aspect-video items-center justify-center rounded-lg bg-base-200">
                      <.icon name="hero-document-text" class="h-16 w-16 text-base-content/20" />
                    </div>
                  </div>
                </div>
              </div>

              <div class="grid gap-8 items-center lg:grid-cols-12">
                <div class="lg:col-span-7">
                  <div class="rounded-xl border border-base-300/50 bg-base-100 p-6">
                    <div class="flex aspect-video items-center justify-center rounded-lg bg-green-100">
                      <.icon name="hero-check-circle" class="h-16 w-16 text-green-600" />
                    </div>
                  </div>
                </div>
                <div class="lg:col-span-5">
                  <div class="mb-4 inline-block rounded-full bg-green-600/10 px-4 py-2 text-sm font-semibold text-green-600">
                    Done
                  </div>
                  <h3 class="mb-4 text-3xl font-bold">You're live!</h3>
                  <p class="text-lg text-base-content/70">
                    Your domain is now powered by HackFlare. Monitor everything from your dashboard!
                  </p>
                </div>
              </div>
            </div>
          </div>
        </section>

        <section class="relative overflow-hidden bg-gradient-to-br from-red-600 to-red-700 px-6 py-20 lg:py-32">
          <div class="absolute inset-0 -z-10 opacity-10">
            <div class="absolute left-1/4 top-0 h-80 w-80 rounded-full bg-white blur-3xl"></div>
            <div class="absolute bottom-0 right-1/4 h-80 w-80 rounded-full bg-white blur-3xl">
            </div>
          </div>

          <div class="relative z-10 mx-auto max-w-4xl text-center">
            <h2 class="text-4xl font-bold leading-tight text-white lg:text-5xl">
              Ready to take control of your DNS?
            </h2>
            <p class="mx-auto mt-6 max-w-2xl text-xl text-red-100">
              Join Hack Club members who've already simplified their DNS infrastructure. Get started free today.
            </p>
            <div class="mt-8 flex flex-col justify-center gap-4 sm:flex-row">
              <a
                href="/dash"
                class="inline-flex items-center justify-center rounded-lg bg-white px-8 py-4 text-lg font-bold text-red-600 transition-colors hover:bg-red-50"
              >
                Get Started Free
              </a>
              <a
                href="/docs"
                class="inline-flex items-center justify-center rounded-lg border-2 border-white px-8 py-4 text-lg font-bold text-white transition-colors hover:bg-white/10"
              >
                Read Documentation
              </a>
            </div>
          </div>
        </section>
      </main>

      <footer class="border-t border-base-300/30 bg-base-200/40">
        <div class="mx-auto max-w-7xl px-6 py-16 lg:px-8">
          <div class="mb-12 grid grid-cols-2 gap-8 md:grid-cols-4 lg:grid-cols-5">
            <div>
              <h4 class="mb-4 text-sm font-semibold">Product</h4>
              <ul class="space-y-3 text-sm text-base-content/70">
                <li><a href="/dash" class="transition hover:text-base-content">Dashboard</a></li>
                <li><a href="/status" class="transition hover:text-base-content">Status</a></li>
                <li><a href="/health" class="transition hover:text-base-content">Health</a></li>
              </ul>
            </div>
            <div>
              <h4 class="mb-4 text-sm font-semibold">Community</h4>
              <ul class="space-y-3 text-sm text-base-content/70">
                <li>
                  <a
                    href="https://github.com/Hack-Flare/hackflare"
                    class="transition hover:text-base-content"
                  >
                    GitHub
                  </a>
                </li>
                <li>
                  <a href="https://hackclub.com" class="transition hover:text-base-content">
                    Hack Club
                  </a>
                </li>
                <li>
                  <a href="https://slack.hackclub.com" class="transition hover:text-base-content">
                    Slack
                  </a>
                </li>
              </ul>
            </div>
            <div>
              <h4 class="mb-4 text-sm font-semibold">Resources</h4>
              <ul class="space-y-3 text-sm text-base-content/70">
                <li><a href="/guides" class="transition hover:text-base-content">Guides</a></li>
                <li>
                  <a href="/docs" class="transition hover:text-base-content">Documentation</a>
                </li>
                <li>
                  <a href="/api" class="transition hover:text-base-content">API Reference</a>
                </li>
              </ul>
            </div>
            <div>
              <h4 class="mb-4 text-sm font-semibold">Us</h4>
              <ul class="space-y-3 text-sm text-base-content/70">
                <li><a href="/about" class="transition hover:text-base-content">About</a></li>
                <li><a href="/privacy" class="transition hover:text-base-content">Privacy</a></li>
                <li><a href="/terms" class="transition hover:text-base-content">Terms</a></li>
              </ul>
            </div>
            <div>
              <div class="mb-4 flex items-center gap-2">
                <img src={~p"/images/logo.svg"} width="32" alt="HackFlare" />
                <span class="font-bold">HackFlare</span>
              </div>
              <p class="text-sm text-base-content/60">DNS for the next generation of builders.</p>
            </div>
          </div>

          <div class="border-t border-base-300/30 pt-8">
            <div class="flex flex-col items-center justify-between gap-4 md:flex-row">
              <p class="text-sm text-base-content/60">
                Built with ❤️ by Hack Clubbers. All rights reserved.
              </p>
              <div class="flex gap-6">
                <a
                  href="https://github.com/Hack-Flare/hackflare"
                  class="text-base-content/60 transition hover:text-base-content"
                >
                  GitHub
                </a>
                <a
                  href="https://hackclub.com"
                  class="text-base-content/60 transition hover:text-base-content"
                >
                  Hack Club
                </a>
              </div>
            </div>
          </div>
        </div>
      </footer>

      <.flash_group flash={@flash} />
    </div>
  </body>
</html>
