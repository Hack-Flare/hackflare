<!DOCTYPE html>
<html>
  <body class="bg-black text-white">
    <div class="flex h-screen">
      <aside class="w-72 overflow-y-auto border-r border-orange-500/20 bg-black/50 p-6">
        <div class="mb-12 flex items-center gap-3">
          <img src={~p"/images/logo.svg"} width="40" alt="HackFlare" />
          <span class="text-lg font-bold text-orange-400">HackFlare</span>
        </div>

        <nav class="space-y-2">
          <a href={~p"/dash"} class={nav_item_class(@current_view, :home)}>
            <.icon name="hero-home" class="h-5 w-5" />
            <span>Home</span>
          </a>
          <a href={~p"/dash/domains"} class={nav_item_class(@current_view, :domains)}>
            <.icon name="hero-globe-alt" class="h-5 w-5" />
            <span>Domains</span>
          </a>
          <a href={~p"/dash/settings"} class={nav_item_class(@current_view, :settings)}>
            <.icon name="hero-cog-6-tooth" class="h-5 w-5" />
            <span>Settings</span>
          </a>
          <a href={~p"/dash/analytics"} class={nav_item_class(@current_view, :analytics)}>
            <.icon name="hero-chart-bar" class="h-5 w-5" />
            <span>Analytics</span>
          </a>
          <a href={~p"/dash/notifications"} class={nav_item_class(@current_view, :notifications)}>
            <.icon name="hero-bell" class="h-5 w-5" />
            <span>Notifications</span>
          </a>
          <a href={~p"/dash/help"} class={nav_item_class(@current_view, :help)}>
            <.icon name="hero-question-mark-circle" class="h-5 w-5" />
            <span>Help</span>
          </a>
          <%= if @current_user && Hackflare.Accounts.admin_user?(@current_user) do %>
            <a href={~p"/admin"} class={nav_item_class(@current_view, :admin)}>
              <.icon name="hero-cog-8-tooth" class="h-5 w-5" />
              <span>Admin Panel</span>
            </a>
          <% end %>
        </nav>

        <div class="absolute bottom-6 left-6 right-6">
          <form method="post" action="/auth/logout" class="flex">
            <input type="hidden" name="_csrf_token" value={get_csrf_token()} />
            <button
              type="submit"
              class="ml-auto inline-flex items-center gap-3 rounded-lg bg-transparent px-4 py-2 text-sm text-gray-300 transition-colors hover:bg-gray-900/50 hover:text-red-400"
            >
              <.icon name="hero-arrow-left-on-rectangle" class="h-5 w-5" />
              <span>Logout</span>
            </button>
          </form>
        </div>
      </aside>

      <main class="flex flex-1 flex-col overflow-hidden">
        <header class="flex items-center justify-between border-b border-orange-500/20 bg-black/30 px-8 py-6">
          <div>
            <h1 class="text-3xl font-bold text-white">{dashboard_title(@current_view)}</h1>
            <p class="mt-1 text-sm text-gray-400">{dashboard_subtitle(@current_view)}</p>
          </div>
          <div class="flex items-center gap-4">
            <button class="rounded-lg p-2 transition-all hover:bg-gray-900/50">
              <.icon name="hero-bell" class="h-6 w-6 text-gray-400 hover:text-orange-400" />
            </button>
            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-primary">
              <span class="font-bold text-white">HC</span>
            </div>
          </div>
        </header>

        <div class="flex-1 overflow-auto p-8">
          <%= case @current_view do %>
            <% :home -> %>
              <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
                <div class="group relative">
                  <div class="hidden"></div>
                  <div class="relative flex h-48 flex-col justify-between rounded-xl border border-orange-500/20 bg-gray-900/50 p-6 transition-all hover:border-orange-500/50">
                    <div>
                      <h3 class="text-lg font-bold text-white">Quick Start</h3>
                      <p class="mt-2 text-sm text-gray-400">Set up your first domain</p>
                    </div>
                    <button class="flex items-center gap-2 font-semibold text-orange-400 transition-colors hover:text-orange-300">
                      <span>Get Started</span>
                      <.icon name="hero-arrow-right" class="h-4 w-4" />
                    </button>
                  </div>
                </div>

                <div class="group relative">
                  <div class="hidden"></div>
                  <div class="relative flex h-48 flex-col justify-between rounded-xl border border-orange-500/20 bg-gray-900/50 p-6 transition-all hover:border-orange-500/50">
                    <div>
                      <h3 class="text-lg font-bold text-white">Your Domains</h3>
                      <p class="mt-2 text-sm text-gray-400">Manage all your domains</p>
                    </div>
                    <button class="flex items-center gap-2 font-semibold text-orange-400 transition-colors hover:text-orange-300">
                      <span>View All</span>
                      <.icon name="hero-arrow-right" class="h-4 w-4" />
                    </button>
                  </div>
                </div>

                <div class="group relative">
                  <div class="hidden"></div>
                  <div class="relative flex h-48 flex-col justify-between rounded-xl border border-orange-500/20 bg-gray-900/50 p-6 transition-all hover:border-orange-500/50">
                    <div>
                      <h3 class="text-lg font-bold text-white">Analytics</h3>
                      <p class="mt-2 text-sm text-gray-400">View your traffic statistics</p>
                    </div>
                    <button class="flex items-center gap-2 font-semibold text-orange-400 transition-colors hover:text-orange-300">
                      <span>View Stats</span>
                      <.icon name="hero-arrow-right" class="h-4 w-4" />
                    </button>
                  </div>
                </div>

                <div class="group relative">
                  <div class="hidden"></div>
                  <div class="relative flex h-48 flex-col justify-between rounded-xl border border-orange-500/20 bg-gray-900/50 p-6 transition-all hover:border-orange-500/50">
                    <div>
                      <h3 class="text-lg font-bold text-white">API Access</h3>
                      <p class="mt-2 text-sm text-gray-400">Integrate with our API</p>
                    </div>
                    <button class="flex items-center gap-2 font-semibold text-orange-400 transition-colors hover:text-orange-300">
                      <span>API Docs</span>
                      <.icon name="hero-arrow-right" class="h-4 w-4" />
                    </button>
                  </div>
                </div>

                <div class="group relative">
                  <div class="hidden"></div>
                  <div class="relative flex h-48 flex-col justify-between rounded-xl border border-orange-500/20 bg-gray-900/50 p-6 transition-all hover:border-orange-500/50">
                    <div>
                      <h3 class="text-lg font-bold text-white">Support</h3>
                      <p class="mt-2 text-sm text-gray-400">Get help when you need it</p>
                    </div>
                    <a
                      href={~p"/dash/help"}
                      class="flex items-center gap-2 font-semibold text-orange-400 transition-colors hover:text-orange-300"
                    >
                      <span>Contact Us</span>
                      <.icon name="hero-arrow-right" class="h-4 w-4" />
                    </a>
                  </div>
                </div>

                <div class="group relative">
                  <div class="hidden"></div>
                  <div class="relative flex h-48 flex-col justify-between rounded-xl border border-orange-500/20 bg-gray-900/50 p-6 transition-all hover:border-orange-500/50">
                    <div>
                      <h3 class="text-lg font-bold text-white">Community</h3>
                      <p class="mt-2 text-sm text-gray-400">Join our Slack community</p>
                    </div>
                    <button class="flex items-center gap-2 font-semibold text-orange-400 transition-colors hover:text-orange-300">
                      <span>Join Now</span>
                      <.icon name="hero-arrow-right" class="h-4 w-4" />
                    </button>
                  </div>
                </div>
              </div>
            <% :domains -> %>
              <% total_zones = Enum.count(@zones || []) %>

              <div class="grid grid-cols-1 gap-6 lg:grid-cols-4">
                <div class="lg:col-span-1">
                  <div class="overflow-hidden rounded-xl border border-orange-500/20 bg-gray-900/60">
                    <div class="border-b border-orange-500/15 bg-black/40 px-4 py-3">
                      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-orange-300">
                        Domains
                      </p>
                      <p class="mt-1 text-xl font-bold text-white">{total_zones}</p>
                    </div>
                    <%= if Enum.empty?(@zones) do %>
                      <div class="p-4 text-center text-sm text-gray-400">No domains yet</div>
                    <% else %>
                      <div class="max-h-96 overflow-y-auto">
                        <%= for zone <- @zones do %>
                          <% zone_name = zone.name %>
                          <% zone_key = String.replace(zone_name, ".", "-") %>
                          <% is_selected = Map.get(assigns, :selected_zone) == zone_name %>
                          <button
                            onclick={"document.querySelectorAll('[data-domain-item]').forEach(el => el.classList.remove('bg-orange-500/10', 'border-orange-400')); document.getElementById('domain-#{zone_key}-item').classList.add('bg-orange-500/10', 'border-orange-400'); document.getElementById('domain-#{zone_key}-panel').classList.remove('hidden');"}
                            data-domain-item
                            data-selected={is_selected}
                            id={"domain-#{zone_key}-item"}
                            class={[
                              "w-full border-l-2 border-transparent px-4 py-2.5 text-left text-sm text-gray-200 transition-all hover:bg-gray-800/50",
                              is_selected && "border-orange-400 bg-orange-500/10"
                            ]}
                          >
                            <p class="truncate font-semibold">{zone_name}</p>
                            <p class="mt-0.5 text-xs text-gray-500">
                              {Enum.count(Map.get(@zone_records || %{}, zone_name, []))} records
                            </p>
                          </button>
                        <% end %>
                      </div>
                    <% end %>
                  </div>
                </div>

                <div class="space-y-4 lg:col-span-3">
                  <%= if Enum.empty?(@zones) do %>
                    <div class="rounded-xl border border-dashed border-orange-500/35 bg-gray-900/50 p-12 text-center">
                      <p class="text-lg font-semibold text-white">No Domains</p>
                      <p class="mt-2 text-sm text-gray-400">
                        Create your first domain to get started.
                      </p>
                      <button
                        onclick="document.getElementById('new-zone-modal').classList.remove('hidden')"
                        class="mt-6 rounded-lg bg-orange-500 px-4 py-2 text-sm font-semibold text-white transition-all hover:bg-orange-400"
                      >
                        + Add Domain
                      </button>
                    </div>
                  <% else %>
                    <%= for zone <- @zones do %>
                      <% zone_name = zone.name %>
                      <% zone_key = String.replace(zone_name, ".", "-") %>
                      <% records = Map.get(@zone_records || %{}, zone_name, []) %>
                      <% is_selected = Map.get(assigns, :selected_zone) == zone_name %>
                      <div
                        id={"domain-#{zone_key}-panel"}
                        class={[is_selected && "space-y-4", !is_selected && "hidden space-y-4"]}
                      >
                        <div class="rounded-xl border border-orange-500/25 bg-black/80 p-6">
                          <div class="flex items-start justify-between gap-4">
                            <div>
                              <p class="text-xs font-semibold uppercase tracking-[0.22em] text-orange-300">
                                Domain
                              </p>
                              <h3 class="mt-2 text-2xl font-bold text-white">{zone_name}</h3>
                              <p class={[
                                "mt-2 text-sm font-medium",
                                zone.ns_verified && "text-emerald-300",
                                !zone.ns_verified && "text-amber-300"
                              ]}>
                                {if zone.ns_verified,
                                  do: "Nameservers verified",
                                  else: "Waiting for nameserver verification"}
                              </p>
                            </div>
                            <div class="flex items-center gap-2">
                              <form
                                method="post"
                                action={~p"/dash/domains/reverify"}
                                class="inline"
                              >
                                <input type="hidden" name="_csrf_token" value={get_csrf_token()} />
                                <input type="hidden" name="zone_name" value={zone_name} />
                                <button
                                  type="submit"
                                  class="rounded-lg bg-amber-600/80 px-4 py-2 text-sm font-semibold text-white transition-all hover:bg-amber-500"
                                >
                                  Re-verify
                                </button>
                              </form>
                              <button
                                onclick={"document.getElementById('add-record-modal-#{zone_key}').classList.remove('hidden')"}
                                class={[
                                  "rounded-lg px-4 py-2 text-sm font-semibold text-white transition-all",
                                  zone.ns_verified && "bg-emerald-600 hover:bg-emerald-500",
                                  !zone.ns_verified &&
                                    "cursor-not-allowed bg-emerald-900/50 opacity-60"
                                ]}
                                disabled={!zone.ns_verified}
                              >
                                + Add Record
                              </button>
                              <button
                                onclick={"if(confirm(\"Delete domain #{zone_name}?\")) { window.location.href = \"/dash/domains/delete/#{zone_key}\" }"}
                                class="rounded-lg bg-red-600/50 px-4 py-2 text-sm font-semibold text-red-100 transition-all hover:bg-red-600"
                              >
                                Delete
                              </button>
                            </div>
                          </div>
                        </div>

                        <div class="overflow-hidden rounded-xl border border-orange-500/20 bg-gray-900/60">
                          <div class="border-b border-orange-500/15 bg-black/40">
                            <div class="flex gap-1 p-1">
                              <button
                                onclick={"document.getElementById('dns-zones-#{zone_key}').classList.remove('hidden'); document.getElementById('other-#{zone_key}').classList.add('hidden');"}
                                class="flex-1 rounded-lg bg-orange-500 px-3 py-2 text-sm font-semibold text-white transition-all hover:bg-orange-400"
                              >
                                DNS Zones
                              </button>
                              <button
                                onclick={"document.getElementById('other-#{zone_key}').classList.remove('hidden'); document.getElementById('dns-zones-#{zone_key}').classList.add('hidden');"}
                                class="flex-1 rounded-lg bg-gray-700/50 px-3 py-2 text-sm font-semibold text-gray-200 transition-all hover:bg-gray-600/50"
                              >
                                More (Soon)
                              </button>
                            </div>
                          </div>

                          <div id={"dns-zones-#{zone_key}"} class="p-4">
                            <%= if Enum.empty?(records) do %>
                              <div class="rounded-lg border border-dashed border-orange-500/30 bg-black/20 px-4 py-6 text-center text-sm text-gray-400">
                                No records in this domain yet.
                              </div>
                            <% else %>
                              <div class="overflow-x-auto rounded-lg border border-orange-500/20">
                                <table class="min-w-full divide-y divide-orange-500/15 text-sm">
                                  <thead class="bg-black/30">
                                    <tr>
                                      <th class="px-4 py-2 text-left font-semibold text-gray-300">
                                        Type
                                      </th>
                                      <th class="px-4 py-2 text-left font-semibold text-gray-300">
                                        Name
                                      </th>
                                      <th class="px-4 py-2 text-left font-semibold text-gray-300">
                                        Content
                                      </th>
                                      <th class="px-4 py-2 text-left font-semibold text-gray-300">
                                        TTL
                                      </th>
                                    </tr>
                                  </thead>
                                  <tbody class="divide-y divide-orange-500/10 bg-gray-900/30">
                                    <%= for record <- records do %>
                                      <tr class="hover:bg-black/30">
                                        <td class="whitespace-nowrap px-4 py-2 font-semibold text-orange-300">
                                          {record.rtype}
                                        </td>
                                        <td class="whitespace-nowrap px-4 py-2 text-gray-200">
                                          {record.name}
                                        </td>
                                        <td class="px-4 py-2 text-gray-300">{record.data}</td>
                                        <td class="whitespace-nowrap px-4 py-2 text-gray-400">
                                          {record.ttl}
                                        </td>
                                      </tr>
                                    <% end %>
                                  </tbody>
                                </table>
                              </div>
                            <% end %>
                          </div>

                          <div
                            id={"other-#{zone_key}"}
                            class="hidden p-4 text-center text-sm text-gray-400"
                          >
                            <p>More features coming soon (SSL, Email, etc.)</p>
                          </div>
                        </div>

                        <div
                          id={"add-record-modal-#{zone_key}"}
                          class="fixed inset-0 z-50 hidden flex items-center justify-center bg-black/60"
                        >
                          <div class="w-full max-w-md rounded-xl border border-orange-500/30 bg-gray-900 p-8 shadow-2xl">
                            <h2 class="mb-1 text-2xl font-bold text-white">Add DNS Record</h2>
                            <p class="mb-4 text-sm text-gray-400">Zone: {zone_name}</p>
                            <form
                              method="post"
                              action={~p"/dash/domains/records/create"}
                              class="space-y-4"
                              onsubmit={"document.getElementById('add-record-modal-" <> zone_key <> "').classList.add('hidden')"}
                            >
                              <input type="hidden" name="_csrf_token" value={get_csrf_token()} />
                              <input type="hidden" name="zone_name" value={zone_name} />
                              <input
                                type="text"
                                name="record_name"
                                placeholder="Record name: @, www, api"
                                class="w-full rounded-lg border border-orange-500/30 bg-black/40 p-3 text-gray-100 focus:border-orange-400 focus:outline-none"
                              />
                              <div class="grid grid-cols-2 gap-3">
                                <select
                                  name="record_type"
                                  class="w-full rounded-lg border border-orange-500/30 bg-black/40 p-3 text-gray-100 focus:border-orange-400 focus:outline-none"
                                >
                                  <option value="A">A</option>
                                  <option value="AAAA">AAAA</option>
                                  <option value="CNAME">CNAME</option>
                                  <option value="MX">MX</option>
                                  <option value="TXT">TXT</option>
                                  <option value="NS">NS</option>
                                </select>
                                <input
                                  type="number"
                                  name="ttl"
                                  min="1"
                                  value="300"
                                  required
                                  class="w-full rounded-lg border border-orange-500/30 bg-black/40 p-3 text-gray-100 focus:border-orange-400 focus:outline-none"
                                />
                              </div>
                              <input
                                type="text"
                                name="record_data"
                                placeholder="Record content"
                                required
                                class="w-full rounded-lg border border-orange-500/30 bg-black/40 p-3 text-gray-100 focus:border-orange-400 focus:outline-none"
                              />
                              <div class="flex gap-3 pt-1">
                                <button
                                  type="button"
                                  onclick={"document.getElementById('add-record-modal-#{zone_key}').classList.add('hidden')"}
                                  class="flex-1 rounded-lg bg-gray-800 px-4 py-2 text-sm font-semibold text-gray-200 transition-all hover:bg-gray-700"
                                >
                                  Cancel
                                </button>
                                <button
                                  type="submit"
                                  class="flex-1 rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white transition-all hover:bg-emerald-500"
                                >
                                  Save Record
                                </button>
                              </div>
                            </form>
                          </div>
                        </div>
                      </div>
                    <% end %>

                    <script>
                      (function() {
                        var selectedDomain = document.querySelector('[data-domain-item][data-selected="true"]');
                        if (selectedDomain) {
                          selectedDomain.click();
                          return;
                        }
                        var firstDomain = document.querySelector('[data-domain-item]');
                        if (firstDomain) {
                          firstDomain.click();
                        }
                      })();
                    </script>
                  <% end %>
                </div>
              </div>

              <div
                class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50"
                id="new-zone-modal"
              >
                <div class="w-full max-w-md rounded-xl border border-orange-500/30 bg-gray-900 p-8 shadow-2xl">
                  <h2 class="mb-4 text-2xl font-bold text-white">Create New Zone</h2>
                  <form
                    method="post"
                    action={~p"/dash/domains/create"}
                    class="space-y-4"
                    onsubmit="document.getElementById('new-zone-modal').classList.add('hidden')"
                  >
                    <input type="hidden" name="_csrf_token" value={get_csrf_token()} />
                    <div>
                      <label class="mb-2 block text-sm font-semibold text-gray-200">
                        Zone Name
                      </label>
                      <input
                        type="text"
                        name="zone_name"
                        placeholder="example.com"
                        required
                        class="w-full rounded-lg border border-orange-500/30 bg-black/40 p-3 text-gray-100 focus:border-orange-400 focus:outline-none"
                      />
                      <p class="mt-1 text-xs text-gray-400">
                        Enter the domain name for this zone
                      </p>
                    </div>
                    <div>
                      <label class="mb-2 block text-sm font-semibold text-gray-200">
                        Zone Type
                      </label>
                      <select
                        name="zone_type"
                        id="zone-type"
                        class="w-full rounded-lg border border-orange-500/30 bg-black/40 p-3 text-gray-100 focus:border-orange-400 focus:outline-none"
                      >
                        <option value="root" selected>Root domain (apex)</option>
                        <option value="subdomain">Subdomain (full name)</option>
                      </select>
                      <p class="mt-1 text-xs text-gray-400">
                        Choose whether this zone is an apex/root domain or a subdomain.
                      </p>
                    </div>
                    <script>
                      (function() {
                        var sel = document.getElementById('zone-type');
                        var nameInput = document.querySelector('input[name="zone_name"]');
                        if (!sel || !nameInput) return;
                        sel.addEventListener('change', function() {
                          if (sel.value === 'subdomain') {
                            nameInput.placeholder = 'blog.example.com';
                            nameInput.setAttribute('title', 'Enter a full subdomain (e.g. blog.example.com)');
                          } else {
                            nameInput.placeholder = 'example.com';
                            nameInput.setAttribute('title', 'Enter the zone apex (e.g. example.com)');
                          }
                        });
                      })();
                    </script>
                    <div class="flex gap-3 pt-4">
                      <button
                        type="button"
                        onclick="document.getElementById('new-zone-modal').classList.add('hidden')"
                        class="flex-1 rounded-lg bg-gray-800 px-4 py-2 font-semibold text-gray-200 transition-all hover:bg-gray-700"
                      >
                        Cancel
                      </button>
                      <button
                        type="submit"
                        class="flex-1 rounded-lg bg-orange-600 px-4 py-2 font-semibold text-white transition-all hover:bg-orange-700"
                      >
                        Create Zone
                      </button>
                    </div>
                  </form>
                </div>
              </div>
            <% :settings -> %>
              <div class="space-y-4">
                <div class="rounded-xl border border-orange-500/20 bg-gray-900/50 p-6">
                  <h3 class="mb-2 text-xl font-bold text-white">Settings</h3>
                  <p class="text-gray-300">
                    Control account, API tokens, and organization defaults.
                  </p>
                </div>
              </div>
            <% :analytics -> %>
              <div class="space-y-4">
                <div class="rounded-xl border border-orange-500/20 bg-gray-900/50 p-6">
                  <h3 class="mb-2 text-xl font-bold text-white">Analytics</h3>
                  <p class="text-gray-300">
                    Traffic, query volume, and performance insights will appear here.
                  </p>
                </div>
              </div>
            <% :notifications -> %>
              <div class="space-y-4">
                <div class="rounded-xl border border-orange-500/20 bg-gray-900/50 p-6">
                  <h3 class="mb-2 text-xl font-bold text-white">Notifications</h3>
                  <p class="text-gray-300">Alert channels and event subscriptions.</p>
                </div>
              </div>
            <% :help -> %>
              <div class="space-y-4">
                <div class="rounded-xl border border-orange-500/20 bg-gray-900/50 p-6">
                  <h3 class="mb-2 text-xl font-bold text-white">Help</h3>
                  <p class="text-gray-300">
                    Get support docs, troubleshooting, and community links.
                  </p>
                </div>
                <div class="rounded-xl border border-orange-500/20 bg-gray-900/30 p-6">
                  <form method="post" action={~p"/dash/help"} class="space-y-4">
                    <input type="hidden" name="_csrf_token" value={get_csrf_token()} />
                    <label class="block text-sm font-semibold text-gray-200" for="help_message">
                      Send us your concerns and questions!
                    </label>
                    <textarea
                      id="help_message"
                      name="help[message]"
                      rows="7"
                      class="w-full rounded-lg border border-orange-500/30 bg-black/40 p-4 text-gray-100 focus:border-orange-400 focus:outline-none"
                      placeholder="Describe issue or question..."
                      required
                    ><%= @form_message %></textarea>
                    <div class="flex justify-end">
                      <button
                        type="submit"
                        class="rounded-lg bg-primary px-6 py-3 font-semibold text-white"
                      >
                        Send
                      </button>
                    </div>
                  </form>
                </div>
              </div>
          <% end %>
        </div>
      </main>
    </div>

    <footer class="border-t border-zinc-800 py-8 text-sm text-zinc-400">
      <div class="mx-auto flex max-w-6xl flex-col gap-4 px-6 md:flex-row md:items-center md:justify-between">
        <p>© 2026 HackFlare. Built by Hack Clubbers.</p>
        <nav class="flex gap-4">
          <a href="/docs" class="hover:text-white">Docs</a>
          <a href="/status" class="hover:text-white">Status</a>
          <a href="/privacy" class="hover:text-white">Privacy</a>
          <a href="https://github.com/Hack-Flare/hackflare" class="hover:text-white">GitHub</a>
        </nav>
      </div>
    </footer>
    <.flash_group flash={@flash} />
  </body>
</html>
