# Example .env, the Passwords and API Keys are not real, please replace them with your own values.
# General API Configuration
API_BIND_ADDR="0.0.0.0:8080"
API_DNS_BIND_ADDR="0.0.0.0:5353"

# Should be generated with high enough entropy
API_JWT_SECRET="abcdefghijklmnopqrstuvwxyz123456"

# Hack Club Auth
API_HCA_CLIENT_ID="your_hackclub_client_id"
API_HCA_CLIENT_SECRET="your_hackclub_client_secret"
API_HCA_REDIRECT_URI="http://localhost:8080/api/v1/auth/callback"

# Database
DATABASE_URL="postgres://hackflare:hackflare@db:5432/hackflare"
